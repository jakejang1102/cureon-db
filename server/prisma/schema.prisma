generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}
model Task {
  id           String    @id @default(cuid())
  title        String
  category     String
  startDate    String
  endDate      String
  partner      String    @default("")
  region       String    @default("")
  status       String
  progress     Int       @default(0)
  managerName  String    @default("")
  managerPhone String    @default("")
  managerEmail String    @default("")
  teamDept     String    @default("")
  teamMembers  String    @default("[]")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  logs         TaskLog[]
}
model TaskLog {
  id      Int    @id @default(autoincrement())
  taskId  String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content String
  date    String
  author  String
}

// ── 신규: 일정 수정 이력 자동 추적 ──
model TaskHistory {
  id        Int      @id @default(autoincrement())
  taskId    String
  action    String   // "create" | "update" | "delete"
  field     String   // 변경된 필드명 (create/delete 시 "all")
  oldValue  String   @default("")
  newValue  String   @default("")
  userName  String   // 변경한 사용자 이름
  createdAt DateTime @default(now())
}
